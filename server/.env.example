# Port the server listens on
PORT=3000

# Host interface to bind to.
# HOST=0.0.0.0 is for development only (binds to all interfaces).
# For LAN-only production binding, set HOST to the server's LAN IP (e.g. 192.168.1.100).
HOST=0.0.0.0

# Sound playback (server-side audio via OS audio player)
SOUND_ENABLED=true
# Optional: override the audio player binary (default: auto-detect per OS)
# SOUND_PLAYER=aplay
