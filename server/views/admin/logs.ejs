<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/_head') %>
</head>
<body>

  <%- include('../partials/_header') %>
  <%- include('../partials/_nav', { active: 'logs' }) %>

  <main class="grid-main">

    <section class="card card-full" id="card-logs">
      <h2>📋 Live Log</h2>

      <div class="log-controls">

        <div class="form-group">
          <label for="log-filter">Source</label>
          <select id="log-filter">
            <option value="all">All sources</option>
          </select>
        </div>

        <div class="form-group">
          <label for="log-maxlines">Max lines</label>
          <input type="number" id="log-maxlines" value="500" min="50" max="5000" step="50">
        </div>

        <label class="log-autoscroll-label">
          <input type="checkbox" id="log-autoscroll" checked>
          Autoscroll
        </label>

        <button id="log-clear" class="btn btn-danger btn-sm">Clear</button>

        <span id="log-status" class="log-status-badge">Connecting…</span>

      </div>

      <div class="log-output-wrapper">
        <div id="log-output" class="log-output" role="log" aria-live="polite" aria-label="Live log output"></div>
      </div>
    </section>

  </main>

  <script src="/js/connection.js"></script>
  <script src="/js/log-viewer.js"></script>

</body>
</html>
