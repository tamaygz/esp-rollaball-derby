<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/_head') %>
</head>
<body>

  <%- include('../partials/_header') %>
  <%- include('../partials/_nav') %>

  <main class="grid-main">

    <!-- Game Status + Controls -->
    <section class="card" id="card-status">
      <h2>Game Status</h2>
      <div class="status-row">
        <span class="label">State</span>
        <span id="game-status-badge" class="badge badge-idle">Idle</span>
      </div>
      <div class="status-row">
        <span class="label">Clients</span>
        <span id="clients-summary" class="muted">—</span>
      </div>
      <div id="winner-banner" class="winner-banner hidden">
        🏆 <strong id="winner-name">—</strong> wins!
      </div>

      <h2 class="card-inner-section">Game Controls</h2>
      <div class="btn-row">
        <button id="btn-start" class="btn btn-success">▶ Start</button>
        <button id="btn-pause" class="btn btn-warning" disabled>⏸ Pause</button>
        <button id="btn-reset" class="btn btn-danger" disabled>↺ Reset</button>
      </div>
      <div id="ctrl-error" class="error-msg hidden"></div>
    </section>

    <!-- Configuration -->
    <section class="card" id="card-config">
      <h2>Configuration</h2>
      <form id="form-config">
        <div class="form-group">
          <label for="cfg-track">Track Length</label>
          <input type="number" id="cfg-track" min="5" max="50" value="15">
        </div>
        <div class="form-group">
          <label for="cfg-max">Max Players</label>
          <input type="number" id="cfg-max" min="1" max="16" value="4">
        </div>
        <div class="form-group">
          <label for="cfg-theme">Theme</label>
          <select id="cfg-theme">
            <option value="auto">🎲 Auto (Random)</option>
            <option value="horse">🐎 Horse Derby</option>
            <option value="camel">🐪 Camel Race</option>
          </select>
        </div>
        <div class="form-group">
          <label for="cfg-countdown">Countdown</label>
          <select id="cfg-countdown">
            <option value="0">None</option>
            <option value="3">3 seconds</option>
            <option value="5" selected>5 seconds</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" id="btn-save-config">Save Config</button>
      </form>
      <div id="config-error" class="error-msg hidden"></div>
    </section>

    <!-- Players -->
    <section class="card card-wide" id="card-players">
      <h2>Players</h2>
      <div id="players-list" class="players-list">
        <p class="empty-msg">No players connected yet.</p>
      </div>
    </section>

    <!-- Bots -->
    <section class="card card-wide" id="card-bots">
      <h2>Bots</h2>
      <p class="hint">Add server-side bot players that autonomously roll at random 2–8 s intervals while the game is running.</p>
      <div class="bot-add-row">
        <button id="btn-add-bot" class="btn btn-primary">🤖 Add Bot</button>
      </div>
      <div id="bot-list" class="bot-list">
        <p class="empty-msg">No bots added yet.</p>
      </div>
    </section>

    <!-- Event Log -->
    <section class="card card-wide" id="card-log">
      <h2>Event Log</h2>
      <ul id="event-log" class="event-log" aria-live="polite" aria-relevant="additions"></ul>
    </section>

  </main>

  <script src="/admin/js/connection.js"></script>
  <script src="/admin/js/state.js"></script>
  <script src="/admin/js/admin.js"></script>
  <script src="/admin/js/bots.js"></script>
  <script src="/admin/js/main.js"></script>
</body>
</html>
