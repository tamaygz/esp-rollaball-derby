<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/_head') %>
</head>
<body>

  <%- include('../partials/_header') %>
  <%- include('../partials/_nav') %>

  <main class="grid-main">

    <!-- LED Configuration -->
    <section class="card card-wide" id="card-led">
      <h2>💡 LED Configuration</h2>
      <div class="led-layout">
        
        <!-- Device List -->
        <div class="led-device-section">
          <h3>Connected Devices</h3>
          <div id="led-device-list" class="led-device-list">
            <p class="empty-msg">No LED-capable devices connected.</p>
          </div>
          <button id="led-sync-all" class="btn btn-secondary btn-sm">Sync All Devices</button>
        </div>

        <!-- Configuration Panel -->
        <div class="led-config-section">
          <h3>LED Settings</h3>
          <p class="hint">Select a device to configure its LED strip.</p>
          
          <div class="form-group">
            <label for="led-count">LED Count</label>
            <input type="number" id="led-count" min="1" max="1000" value="50">
            <span id="led-count-hint" class="hint">max 1000 LEDs</span>
          </div>

          <div class="form-group">
            <label for="led-pin">GPIO Pin</label>
            <select id="led-pin">
              <optgroup id="led-pin-esp8266" label="ESP8266 pins">
                <option value="2">D4 / GPIO2 (UART1 — leaves Serial free)</option>
                <option value="3">RX / GPIO3 (DMA — uses RX pin)</option>
              </optgroup>
              <optgroup id="led-pin-esp32" label="ESP32 pins">
                <option value="4">GPIO4 (RMT ch0 — default matrix pin)</option>
                <option value="13">GPIO13 (RMT ch1)</option>
                <option value="14">GPIO14 (RMT ch2)</option>
                <option value="16">GPIO16 (RMT ch3)</option>
                <option value="17">GPIO17 (RMT ch4)</option>
                <option value="18">GPIO18 (RMT ch5)</option>
                <option value="19">GPIO19 (RMT ch6)</option>
                <option value="21">GPIO21 (RMT ch7)</option>
              </optgroup>
            </select>
            <small id="led-pin-hint" class="hint"></small>
          </div>

          <div class="form-group">
            <label for="led-topology">Topology</label>
            <select id="led-topology">
              <option value="strip" selected>Strip (Linear)</option>
              <option value="matrix_zigzag">Matrix (Zigzag)</option>
              <option value="matrix_progressive">Matrix (Progressive)</option>
              <option value="ring">Ring (Circular)</option>
            </select>
          </div>

          <div id="led-matrix-dims" class="form-group hidden">
            <label>Matrix Dimensions</label>
            <div class="form-row">
              <input type="number" id="led-matrix-rows" min="4" max="32" value="8" placeholder="Rows">
              <span>×</span>
              <input type="number" id="led-matrix-cols" min="4" max="32" value="8" placeholder="Cols">
            </div>
          </div>

          <div class="form-group">
            <label for="led-brightness">Brightness (%)</label>
            <input type="range" id="led-brightness" min="0" max="100" value="80">
            <span id="led-brightness-value">80%</span>
          </div>

          <button id="led-save-config" class="btn btn-success">Save Configuration</button>
          <div id="led-error" class="error-msg hidden"></div>
          <div id="led-success" class="success-msg hidden"></div>
        </div>

        <!-- Preview & Effects -->
        <div class="led-preview-section">
          <h3>LED Preview</h3>
          <canvas id="led-simulator" class="led-simulator"></canvas>

          <h3>Test Effects</h3>
          <div class="form-group">
            <label for="led-effect-select">Effect</label>
            <select id="led-effect-select">
              <option value="">— Select Effect —</option>
              <option value="solid">Solid Color</option>
              <option value="blink">Blink</option>
              <option value="pulse">Pulse (Breathing)</option>
              <option value="rainbow">Rainbow</option>
              <option value="chase">Chase</option>
              <option value="sparkle">Sparkle</option>
            </select>
          </div>

          <div class="form-group">
            <label for="led-color">Color</label>
            <select id="led-color">
              <!-- Populated by led-admin.js -->
            </select>
          </div>

          <div class="form-group">
            <label for="led-speed">Speed (ms)</label>
            <input type="range" id="led-speed" min="100" max="5000" value="1000">
            <span id="led-speed-value">1000ms</span>
          </div>

          <button id="led-test-effect" class="btn btn-primary">Test on Device</button>
        </div>

      </div>
    </section>

  </main>

  <script src="/admin/js/connection.js"></script>
  <script src="/admin/js/led-effects.js"></script>
  <script src="/admin/js/led-simulator.js"></script>
  <script src="/admin/js/led-admin.js"></script>
  <script src="/admin/js/led-main.js"></script>
</body>
</html>
