<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/_head') %>
</head>
<body>

  <%- include('../partials/_header') %>
  <%- include('../partials/_nav') %>

  <main class="grid-main">

    <!-- Summary + refresh -->
    <section class="card card-wide" id="card-summary">
      <h2>Connected Devices</h2>
      <div id="devices-summary" class="devices-summary">
        <span class="muted">Loading…</span>
      </div>
      <div id="mdns-info" class="mdns-info muted text-sm" style="margin-top: 0.5em;"></div>
      <div class="refresh-row">
        <span id="refresh-status" class="muted text-sm">—</span>
        <button id="btn-refresh" class="btn btn-secondary btn-sm">↺ Refresh</button>
      </div>
    </section>

    <!-- Sensor devices -->
    <section class="card" id="card-sensors">
      <h2>🎯 Sensors</h2>
      <div id="sensor-list" class="device-list">
        <p class="empty-msg">No sensor clients connected.</p>
      </div>
    </section>

    <!-- Motor devices -->
    <section class="card" id="card-motors">
      <h2>⚙️ Motors</h2>
      <div id="motor-list" class="device-list">
        <p class="empty-msg">No motor clients connected.</p>
      </div>
    </section>

    <!-- Display devices -->
    <section class="card" id="card-displays">
      <h2>🖥️ Displays</h2>
      <div id="display-list" class="device-list">
        <p class="empty-msg">No display clients connected.</p>
      </div>
    </section>

    <!-- Web clients -->
    <section class="card" id="card-web">
      <h2>🌐 Web</h2>
      <div id="web-list" class="device-list">
        <p class="empty-msg">No web clients connected.</p>
      </div>
    </section>

    <!-- Unregistered -->
    <section class="card card-wide" id="card-unregistered">
      <h2>⚪ Unregistered</h2>
      <p class="hint">Clients that have connected but not yet sent a register message.</p>
      <div id="unregistered-list" class="device-list">
        <p class="empty-msg">No unregistered clients.</p>
      </div>
    </section>

    <!-- Remote sensor config -->
    <section class="card card-wide" id="card-sensor-config">
      <h2>📡 Remote Sensor Config</h2>
      <p class="hint">Push server connection details to a sensor already on the local network. The sensor will save the new config and reboot.</p>
      <form id="sensor-config-form" class="sensor-config-form" autocomplete="off">
        <div class="sensor-config-fields">
          <div class="form-group">
            <label for="input-sensor-ip">Sensor IP</label>
            <input id="input-sensor-ip" type="text" placeholder="192.168.1.x" maxlength="39">
          </div>
          <div class="form-group">
            <label for="input-server-ip">Server IP</label>
            <input id="input-server-ip" type="text" maxlength="39">
          </div>
          <div class="form-group">
            <label for="input-server-port">Server Port</label>
            <input id="input-server-port" type="text" maxlength="5">
          </div>
          <div class="form-group">
            <label for="input-player-name">Player Name <span class="muted">(optional)</span></label>
            <input id="input-player-name" type="text" maxlength="20" placeholder="leave blank to keep current">
          </div>
        </div>
        <div class="btn-row">
          <button type="submit" id="btn-sensor-config" class="btn btn-primary">⚡ Configure Sensor</button>
          <span id="sensor-config-status" class="muted text-sm"></span>
        </div>
      </form>
    </section>

    <!-- Motor Control Panel (shown when a motor client is selected) -->
    <section class="card card-wide" id="card-motor-control" style="display:none">
      <div class="motor-ctrl-header">
        <h2>⚙️ Motor Control</h2>
        <span id="motor-ctrl-device-label" class="muted text-sm"></span>
        <button id="btn-motor-ctrl-close" class="btn btn-secondary btn-sm" style="margin-left:auto">✕ Close</button>
      </div>

      <!-- Status grid -->
      <div class="motor-ctrl-block">
        <h3>Lane Status</h3>
        <div id="motor-lane-grid" class="motor-lane-grid">
          <p class="empty-msg">Loading…</p>
        </div>
        <div class="btn-row">
          <button id="btn-motor-home-all" class="btn btn-secondary btn-sm">⌂ Home All</button>
          <span id="motor-status-msg" class="muted text-sm"></span>
        </div>
      </div>

      <!-- Jog controls -->
      <div class="motor-ctrl-block">
        <h3>Jog Lane</h3>
        <div class="motor-jog-row">
          <label for="sel-jog-lane">Lane</label>
          <select id="sel-jog-lane" class="input-sm"></select>
          <label>Steps</label>
          <div class="btn-group">
            <button class="btn btn-sm btn-secondary jog-size-btn active" data-steps="1">1</button>
            <button class="btn btn-sm btn-secondary jog-size-btn" data-steps="10">10</button>
            <button class="btn btn-sm btn-secondary jog-size-btn" data-steps="100">100</button>
            <button class="btn btn-sm btn-secondary jog-size-btn" data-steps="500">500</button>
          </div>
          <button id="btn-jog-back" class="btn btn-primary btn-sm">◀ Back</button>
          <button id="btn-jog-fwd"  class="btn btn-primary btn-sm">Fwd ▶</button>
        </div>
      </div>

      <!-- Track Color Assignment -->
      <div class="motor-ctrl-block">
        <h3>Track Colors</h3>
        <p class="hint">Assign the physical horse/ball color to each motor lane. The motor uses this to follow the correct player.</p>
        <div id="motor-track-colors" class="motor-track-colors">
          <p class="empty-msg muted">Open a motor device first.</p>
        </div>
        <div class="btn-row" style="margin-top:10px">
          <button id="btn-track-colors-save" class="btn btn-primary btn-sm">💾 Save Track Colors</button>
          <span id="track-colors-status" class="muted text-sm"></span>
        </div>
      </div>

      <!-- Calibration workflow -->
      <div class="motor-ctrl-block">
        <h3>Calibration</h3>
        <div class="motor-jog-row">
          <label for="sel-calib-lane">Lane</label>
          <select id="sel-calib-lane" class="input-sm"></select>
        </div>
        <div class="btn-row" style="flex-wrap:wrap;gap:0.4em">
          <button id="btn-calib-start"     class="btn btn-secondary btn-sm">▶ Start Calib</button>
          <button id="btn-calib-set-start" class="btn btn-secondary btn-sm">📍 Set Start</button>
          <button id="btn-calib-set-end"   class="btn btn-secondary btn-sm">🏁 Set End</button>
          <button id="btn-calib-finish"    class="btn btn-primary btn-sm">✅ Finish</button>
          <button id="btn-calib-reset"     class="btn btn-danger btn-sm">🔄 Reset</button>
        </div>
        <p id="calib-status-msg" class="text-sm muted" style="margin-top:0.4em"></p>
      </div>

      <!-- Bluetooth management -->
      <div class="motor-ctrl-block">
        <h3>Bluetooth Audio</h3>
        <div id="bt-status-row" class="bt-status-row">
          <span id="bt-status-label" class="muted">Loading…</span>
          <button id="btn-bt-scan"       class="btn btn-secondary btn-sm">🔍 Scan</button>
          <button id="btn-bt-connect"    class="btn btn-primary btn-sm"   style="display:none">🔗 Connect</button>
          <button id="btn-bt-disconnect" class="btn btn-secondary btn-sm" style="display:none">🔌 Disconnect</button>
          <button id="btn-bt-unpair"     class="btn btn-danger btn-sm"   n-sm"   style="display:none">🔗 Connect</button>
          <button id="btn-bt-disconnect" class="btn btn-secondary btn-sm" style="display:none">🔌 Disconnect</button>
          <button id="btn-bt-unpair"     class="btn btn-danger btn-sm"    style="display:none">⛔ Unpair</button>
        </div>
        <div id="bt-device-list" class="bt-device-list"></div>
        <div class="bt-play-row" style="display:flex;align-items:center;gap:0.5em;margin-top:0.5em">
          <select id="bt-sound-event" class="input-sm">
            <option value="winner">Winner fanfare</option>
            <option value="game_started">Game started</option>
            <option value="countdown_go">Countdown — go!</option>
            <option value="countdown_tick">Countdown tick</option>
            <option value="score_1">Score +1</option>
            <option value="score_2">Score +2</option>
            <option value="score_3">Score +3</option>
            <option value="took_lead">Took lead</option>
            <option value="became_last">Became last</option>
            <option value="button_click">Button click</option>
          </select>
          <button id="btn-bt-play" class="btn btn-secondary btn-sm">🔊 Play</button>
        </div>
        <p id="bt-status-msg" class="text-sm muted" style="margin-top:0.4em"></p>
      </div>
    </section>

  </main>

  <script src="/admin/js/devices.js"></script>
</body>
</html>
