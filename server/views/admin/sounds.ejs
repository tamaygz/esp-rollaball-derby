<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/_head') %>
</head>
<body>

  <%- include('../partials/_header') %>
  <%- include('../partials/_nav') %>

  <main class="grid-main">

    <section class="card card-wide" id="card-sounds">
      <h2>🔊 Sound Configuration</h2>
      <p class="hint">
        Per-event audio URLs used by all browser clients (Display, Admin). An override wins over the
        local <code>server/sounds/</code> file. URLs may be absolute (<code>https://…</code>) or
        site-relative (<code>/sounds/foo.wav</code>, <code>/assets/sounds/…</code>). Leave blank to
        fall back to the default.
      </p>

      <div class="btn-row" style="margin-bottom: 8px;">
        <button id="btn-sounds-save" class="btn btn-success">Save</button>
        <button id="btn-sounds-reset" class="btn btn-secondary">Reset unsaved changes</button>
        <span id="sounds-status" class="muted text-sm"></span>
      </div>
      <div id="sounds-error" class="error-msg hidden"></div>

      <table id="sounds-table" class="sounds-table">
        <thead>
          <tr>
            <th>Event</th>
            <th>Default</th>
            <th>URL override</th>
            <th style="width: 90px;">Preview</th>
          </tr>
        </thead>
        <tbody id="sounds-tbody">
          <tr><td colspan="4" class="muted">Loading…</td></tr>
        </tbody>
      </table>
    </section>

    <section class="card card-wide" id="card-sounds-music">
      <h2>🎵 Background Music</h2>
      <p class="hint">
        Configure background music for lobby and in-game modes. URLs must be direct audio file links
        (MP3, OGG, WAV). One URL per line. Music is only played on the Display client.
      </p>

      <h3>Volume Levels</h3>
      <div id="sounds-volumes">
        <p class="muted">Loading…</p>
      </div>

      <h3>Lobby Music</h3>
      <p class="hint">Played on shuffle-loop while no game is active. Falls back to Fallback Music if empty.</p>
      <div class="sounds-subsection">
        <textarea id="lobby-music-urls" class="music-urls" rows="3"
                  placeholder="https://example.com/lobby-track.mp3"></textarea>
        <button type="button" class="btn btn-secondary btn-sm music-preview-btn"
                data-preview-source="lobby">▶ Preview first</button>
      </div>

      <h3>Theme Background Music</h3>
      <p class="hint">Played on random infinite loop during a game. One URL per line per theme. Falls back to Fallback Music if empty.</p>
      <div id="theme-music-sections">
        <p class="muted">Loading themes…</p>
      </div>

      <h3>Fallback Music</h3>
      <p class="hint">Used when lobby or theme music is not configured for the active context.</p>
      <div class="sounds-subsection">
        <textarea id="fallback-music-urls" class="music-urls" rows="3"
                  placeholder="https://example.com/fallback-track.mp3"></textarea>
        <button type="button" class="btn btn-secondary btn-sm music-preview-btn"
                data-preview-source="fallback">▶ Preview first</button>
      </div>
    </section>

  </main>

  <script src="/shared/js/gameEvents.js"></script>
  <script src="/shared/js/AudioPlayer.js"></script>
  <script src="/admin/js/sounds.js"></script>
</body>
</html>
